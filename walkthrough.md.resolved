## 12. Kiến Trúc Dữ Liệu (Firebase Collections)

```mermaid
erDiagram
    USERS ||--o{ LIKES : "gửi/nhận"
    USERS ||--o{ MATCHES : "tham gia"
    USERS ||--o{ CHATS : "tham gia"
    USERS ||--o{ MESSAGES : "gửi"
    USERS ||--o{ STUDY_GROUPS : "tạo/tham gia"
    USERS ||--o{ SWIPE_GROUPS : "tạo/tham gia"
    USERS ||--o{ NOTIFICATIONS : "nhận"
    USERS ||--o{ REPORTS : "gửi/bị báo cáo"
    USERS ||--o{ TOKEN_TRANSACTIONS : "có"
    USERS ||--o{ FRIEND_CODES : "sở hữu"

    MATCHES ||--|| CHATS : "tạo"
    CHATS ||--o{ MESSAGES : "chứa"
    STUDY_GROUPS ||--|| CHATS : "có"
    SWIPE_GROUPS ||--o{ GROUP_JOIN_REQUESTS : "nhận"
    VOUCHERS ||--o{ VOUCHER_REDEMPTIONS : "được đổi"

    USERS {
        string uid PK
        string email
        string displayName
        string school
        array interests
        boolean isPremium
        number tokens
        number dailySwipes
    }

    MATCHES {
        string id PK
        array users
        string chatId
    }

    CHATS {
        string id PK
        string type
        array participants
    }
```
